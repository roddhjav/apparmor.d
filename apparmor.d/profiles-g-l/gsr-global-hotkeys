abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/gsr-global-hotkeys
profile gsr-global-hotkeys @{exec_path} {
  include <abstractions/base>
  include <abstractions/input>
  include <abstractions/uinput>

  @{exec_path} r,

  capability setuid,

  network netlink dgram,

  @{PROC}/bus/input/devices r,

  include if exists <local/gsr-global-hotkeys>
}

# vim:syntax=apparmor
