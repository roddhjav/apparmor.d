abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lact
profile lact @{exec_path} {
  include <abstractions/base>
  include <abstractions/dconf-write>
  include <abstractions/desktop>
  include <abstractions/graphics-full>
  include <abstractions/hwmon>
  include <abstractions/nameservice-strict>
  include <abstractions/sys/gpumon>
  include <abstractions/sys/hwmon-power:w>
  include <abstractions/sys/hwmon-pwm:w>

  capability sys_admin,
  capability chown,

  network netlink raw,

  @{exec_path} mr,

  @{bin}/clinfo       cx -> clinfo,
  @{bin}/uname       rPx,
  @{bin}/vulkaninfo   cx -> vulkaninfo,

  ##aa:only pacman
  @{bin}/mkinitcpio   cx -> mkinitcpio,

  /etc/lact/ r,
  /etc/lact/config.yaml rw,

  owner @{user_config_dirs}/lact/ui.yaml rw,

  @{PROC}/cmdline r,
  @{PROC}/sys/kernel/random/boot_id r,
  @{PROC}/uptime r,

  @{run}/lactd.sock rw,
  @{run}/systemd/userdb/ r,

  @{sys}/devices/@{pci}/mem_info_vram_vendor r,
  @{sys}/devices/@{pci}/hwmon/hwmon@{int}/pwm@{int}_max r,
  @{sys}/devices/@{pci}/hwmon/hwmon@{int}/pwm@{int}_min r,
  @{sys}/devices/@{pci}/power_dpm_force_performance_level w, #amdgpu abs doesn't allow write
  @{sys}/devices/@{pci}/pp_od_clk_voltage w, # ^
  @{sys}/module/amdgpu/parameters/ppfeaturemask r,

  /tmp/VP_VULKANINFO*.json rw,

  profile clinfo flags=(complain) {
    include <abstractions/base>
    include <abstractions/nameservice-strict>

    @{bin}/clinfo r,

    network netlink raw,

    include if exists <local/lact_clinfo>
  }

  profile vulkaninfo flags=(complain) {
    include <abstractions/base>
    include <abstractions/graphics>
    include <abstractions/nameservice-strict>

    capability dac_read_search,
    capability dac_override,

    network netlink raw,

    @{bin}/vulkaninfo mr,

    /tmp/VP_VULKANINFO*.json rw,

    deny capability sys_admin,

    include if exists <local/lact_vulkaninfo>
  }

  ##aa:only pacman
  profile mkinitcpio flags=(complain) {
    include <abstractions/base>
    include <abstractions/nameservice-strict>

    @{bin}/mkinitcpio r,

    @{sh_path} rix,
    @{bin}/cat rix,
    @{bin}/env r,

    /dev/tty rw,

    @{lib}/gconv/gconv-modules.cache r,
    @{lib}/initcpio/functions r,

    include if exists <local/lact_mkinitcpio>
  }

  include if exists <local/lact>
}

# vim:syntax=apparmor
