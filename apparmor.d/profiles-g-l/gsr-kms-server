abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/gsr-kms-server
profile gsr-kms-server @{exec_path} {
  include <abstractions/base>
  include <abstractions/dri>

  capability sys_admin,

  network unix stream,
  network unix dgram,

  signal (receive) set=(kill) peer=gpu-screen-recorder,

  @{exec_path} mr,

  /usr/share/gsr-ui/fonts/{,**} r,

  /tmp/.gsr-kms-socket-* rw,

  include if exists <local/gsr-kms-server>
}

# vim:syntax=apparmor
