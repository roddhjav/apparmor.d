abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/gsr-kwin-helper
profile gsr-kwin-helper @{exec_path} {
  include <abstractions/base>

  signal (receive) set=(kill) peer=gsr-ui,

  @{exec_path} r,

  /dev/dri/card@{int} r,

  deny /dev/input/event@{int} r, # file_inherit

  include if exists <local/gsr-kwin-helper>
}

# vim:syntax=apparmor
