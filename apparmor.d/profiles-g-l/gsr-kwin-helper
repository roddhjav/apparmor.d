abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/gsr-kwin-helper

profile gsr-kwin-helper @{exec_path} {
  include <abstractions/base>

  @{exec_path} r,

  /dev/dri/card@{int} r,

  include if exists <abstractions/gsr-kwin-helper>
}

# vim:syntax=apparmor
