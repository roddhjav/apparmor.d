abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/showtime
profile showtime @{exec_path} flags=(attach_disconnected) {
  include <abstractions/base>
  include <abstractions/audio-client>
  include <abstractions/common/gnome>
  include <abstractions/gstreamer>
  include <abstractions/mpris>
  include <abstractions/python>

  @{exec_path} mr,

  @{open_path}       Px -> child-open-help,

  /usr/share/xml/iso-codes/{,**} r,

  owner @{user_music_dirs}/{,**} rw,
  owner @{user_pictures_dirs}/{,**} rw,
  owner @{user_torrents_dirs}/{,**} rw,
  owner @{user_videos_dirs}/{,**} rw,

  owner @{PROC}/@{pid}/mounts r,

  include if exists <local/showtime>
}

# vim:syntax=apparmor
