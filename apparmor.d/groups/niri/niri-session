abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/niri-session
profile niri-session @{exec_path} {
  include <abstractions/base>

  /etc/shells r,
  /dev/tty rw,
  /dev/tty@{int} rw,

  @{exec_path} mrix,
  @{shells_path} rix,
  @{bin}/dbus-update-activation-environment rix,
  @{bin}/niri rpx,
  @{bin}/grep rix,
  @{bin}/systemctl            rcx -> systemctl,

  owner /dev/tty@{u8} rw,

  profile systemctl flags=(attach_disconnected,mediate_deleted,complain) {
    include <abstractions/base>
    include <abstractions/app/systemctl>

    include if exists <local/sddm_systemctl>
  }
}

# vim:syntax=apparmor
