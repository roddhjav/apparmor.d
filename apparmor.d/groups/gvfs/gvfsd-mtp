abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{lib}/{,gvfs/}gvfsd-mtp
profile gvfsd-mtp @{exec_path} {
  include <abstractions/base>
  include <abstractions/bus-session>
  include <abstractions/gvfs-backend>
  include <abstractions/dconf-write>
  include <abstractions/deny-sensitive-home>
  include <abstractions/devices-usb>
  include <abstractions/private-files-strict>
  include <abstractions/user-download-strict>

  network netlink raw,

  @{exec_path} mr,

  /usr/share/mime/aliases r,
  /usr/share/mime/generic-icons r,
  /usr/share/mime/globs2 r,
  /usr/share/mime/icons r,
  /usr/share/mime/magic r,
  /usr/share/mime/mime.cache r,
  /usr/share/mime/subclasses r,

  owner @{HOME}/ r,
  owner @{HOME}/** rw,
  owner @{MOUNTS}/** rw,

  owner @{run}/user/@{uid}/gvfsd/socket-@{rand8} rw,

  @{sys}/devices/@{pci}/uevent r,
  @{sys}/devices/@{pci_bus}/uevent r,

  include if exists <local/gvfsd-mtp>
}

# vim:syntax=apparmor
