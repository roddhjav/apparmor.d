abi <abi/4.0>,

include <tunables/global>

@{lib_dirs} = @{lib}/postgresql/@{version}/
@{bin_dirs} = @{lib_dirs}/bin

@{exec_path} = @{bin_dirs}/psql
profile psql @{exec_path} {
  include <abstractions/base>
  include <abstractions/consoles>
  include <abstractions/nameservice-strict>

  network inet dgram peer=(port=5433),
  network inet stream peer=(port=5433),
  network inet6 dgram peer=(port=5433),
  network inet6 stream peer=(port=5433),
  network netlink raw,

  @{exec_path} mr,

  /etc/gss/mech.d/{,*} r,

  include if exists <local/psql>
}

# vim:syntax=apparmor
