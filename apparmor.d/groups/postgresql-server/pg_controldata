abi <abi/4.0>,

include <tunables/global>

@{lib_dirs} = @{lib}/postgresql/@{version}/
@{bin_dirs} = @{lib_dirs}/bin

@{exec_path} = @{bin_dirs}/pg_controldata
profile pg_controldata @{exec_path} {
  include <abstractions/base>

  capability dac_read_search,

  @{exec_path} mr,

  /var/lib/postgresql/**/pg_control r,

  #aa:only test
  # Throw-away PostgreSQL environment for running regression tests
  owner /tmp/pg_virtualenv.@{rand6}/{,**} rw,
  owner /tmp/tmp.@{rand10}/{,**} rw,

  include if exists <local/pg_controldata>
}

# vim:syntax=apparmor
