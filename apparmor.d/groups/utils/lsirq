abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lsirq
profile lsirq @{exec_path} {
  include <abstractions/base>
  include <abstractions/consoles>

  @{exec_path} mr,

  @{PROC}/interrupts r,

  include if exists <local/lsirq>
}

# vim:syntax=apparmor
