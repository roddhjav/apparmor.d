abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/sleep
profile sleep @{exec_path} flags=(attach_disconnected) {
  include <abstractions/base>

  signal receive set=term,

  @{exec_path} mr,

  # file_inherit
  deny owner /dev/pts/@{u8} rw,

  include if exists <local/sleep>
}

# vim:syntax=apparmor
