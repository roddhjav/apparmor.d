abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lsclocks
profile lsclocks @{exec_path} {
  include <abstractions/base>
  include <abstractions/consoles>

  @{exec_path} mr,

  /dev/ r,

  include if exists <local/lsclocks>
}

# vim:syntax=apparmor
