abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/docker
profile docker @{exec_path} flags=(attach_disconnected) {
  include <abstractions/base>
  include <abstractions/consoles>

  capability dac_read_search,

  network netlink raw,

  @{exec_path} mr,

  @{lib}/docker/cli-plugins/docker-buildx Px,

  @{run}/docker.sock rw,

  owner @{PROC}/@{pid}/cgroup r,
  owner @{PROC}/@{pid}/mountinfo r,

  include if exists <local/docker>
}

# vim:syntax=apparmor
