abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/pkill
profile pkill @{exec_path} {
  include <abstractions/base>
  include <abstractions/app/pgrep>

  capability kill,

  signal send,

  @{exec_path} mr,

  include if exists <local/pkill>
}

# vim:syntax=apparmor
