# Base files required by any GUI on any desktop environment.
#
# It should only contain basic files required everywhere. It is intended to be
# included in desktop environment specific abstractions, and not directly in profiles.

  abi <abi/4.0>,

  /usr/share/desktop-base/{,**} r,
  /usr/share/hwdata/*.ids r,
  /usr/share/icu/@{int}.@{int}/*.dat r,
  /usr/share/poppler/{,**} r,

  include if exists <abstractions/desktop-base.d>

# vim:syntax=apparmor
